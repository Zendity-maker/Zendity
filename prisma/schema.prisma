model ShiftHandover {
  id             String @id @default(uuid())
  headquartersId String

  shiftType       ShiftType // MORNING (6am-2pm), EVENING (2pm-10pm), NIGHT (10pm-6am)
  outgoingNurseId String? // Enfermera que entrega el turno (Null si lo generó Zendi AI sin usuario base)
  incomingNurseId String? // Enfermera que recibe el turno (Null si aún no lo ha aceptado)

  status     HandoverStatus @default(PENDING) // PENDING, ACCEPTED
  createdAt  DateTime       @default(now())
  acceptedAt DateTime?

  headquarters  Headquarters   @relation(fields: [headquartersId], references: [id])
  outgoingNurse User?          @relation("OutgoingNurse", fields: [outgoingNurseId], references: [id])
  incomingNurse User?          @relation("IncomingNurse", fields: [incomingNurseId], references: [id])
  notes         HandoverNote[]

  // FASE 61: Zendi AI Handovers (5:45 AM Digest)
  aiSummaryReport String? @db.Text
  audioUrl        String?

  // Sprint B: Firma + justificaciones recolectadas por ShiftClosureWizard
  signature          String?   @db.Text // Firma electrónica del outgoing (base64 o token)
  signedOutAt        DateTime?
  justifications     Json?     // { warningId: "REFUSED" | "ASLEEP" | "TRANSFERRED" | ... }
  handoverCompleted  Boolean   @default(false)

  // Sprint D: Confirmación Senior + Firma Supervisor + Tracking Director
  seniorCaregiverId    String?
  seniorConfirmedAt    DateTime?
  seniorNote           String?   @db.Text
  supervisorSignedById String?
  supervisorSignedAt   DateTime?
  supervisorSignature  String?   @db.Text
  supervisorNote       String?   @db.Text
  directorViewedAt     DateTime?

  seniorCaregiver  User? @relation("SeniorCaregiver",   fields: [seniorCaregiverId],    references: [id])
  supervisorSigned User? @relation("SupervisorSigned",  fields: [supervisorSignedById], references: [id])

  // Enlace a la Sesión de Turno (Fase 44)
  shiftSession ShiftSession?
}

model HandoverNote {
  id              String @id @default(uuid())
  shiftHandoverId String
  patientId       String

  clinicalNotes String // Novedades: "Paciente con fiebre en la tarde, seguir protocolo"
  isCritical    Boolean @default(false)

  shiftHandover ShiftHandover @relation(fields: [shiftHandoverId], references: [id], onDelete: Cascade)
  patient       Patient       @relation(fields: [patientId], references: [id])
}

enum ShiftType {
  MORNING
  EVENING
  NIGHT
  SUPERVISOR_DAY
}

enum HandoverStatus {
  PENDING
  ACCEPTED
}

