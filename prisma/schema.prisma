// =======================
// SUPERVISIÓN OPERACIONAL (MVP FINAL)
// =======================

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketOriginType {
  EMAR_MISS
  DAILY_LOG
  INCIDENT
  COMPLAINT
  FALL
  CRON_SYSTEM
  MANUAL
}

enum EscalationReason {
  SLA_BREACH_120M
  MANUAL_BY_SUPERVISOR
  CRITICAL_INCIDENT_AUTO
}

enum SignatureStatus {
  PENDING
  SIGNED
  INVALIDATED
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
  WHATSAPP
}

enum SemaphoreColor {
  GREEN
  YELLOW
  RED
}

enum SystemAuditAction {
  CREATED
  STATE_CHANGED
  ESCALATED
  RESOLVED
  SIGNED_OUT
  ACCEPTED_IN
  SYSTEM_ABANDONED
  VOIDED
}

// =======================
// MODELOS DE DOMINIO MVP
// =======================

model TriageTicket {
  id                String           @id @default(uuid())
  headquartersId    String
  patientId         String?
  originType        TicketOriginType
  originReferenceId String?

  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  isEscalated Boolean        @default(false)
  isVoided    Boolean        @default(false)

  description    String  @db.Text
  resolutionNote String? @db.Text
  followUpNotes  Json?   // Array de { authorId, authorName, note, createdAt }

  assignedToId String?
  resolvedById String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  escalatedAt DateTime?
  resolvedAt  DateTime?

  headquarters Headquarters @relation(fields: [headquartersId], references: [id])
  patient      Patient?     @relation(fields: [patientId], references: [id])
  assignedTo   User?        @relation("TicketAssignee", fields: [assignedToId], references: [id])
  resolvedBy   User?        @relation("TicketResolver", fields: [resolvedById], references: [id])

  @@index([headquartersId, status, priority, isEscalated, isVoided])
}

model SystemAuditLog {
  id             String @id @default(uuid())
  headquartersId String

  entityName String
  entityId   String
  action     SystemAuditAction

  performedById  String?
  payloadChanges Json?
  clientIp       String?

  createdAt DateTime @default(now())

  headquarters Headquarters @relation(fields: [headquartersId], references: [id])

  @@index([headquartersId, entityName, entityId])
  @@index([createdAt])
}

// =======================
// 5. ZENDITY CALENDAR ENGINE
// =======================

enum CalendarEventType {
  MEDICAL_APPOINTMENT
  REEVALUATION_DUE
  THERAPY
  FACILITY_ROUTINE
}

enum CalendarEventStatus {
  SCHEDULED
  COMPLETED
  DISMISSED
}

model CalendarEvent {
  id             String  @id @default(uuid())
  headquartersId String // Tenant Middleware Anchor
  patientId      String?
  assignedToId   String?

  type   CalendarEventType
  status CalendarEventStatus @default(SCHEDULED)

  title         String
  description   String? @db.Text
  originContext String

  startTime DateTime
  endTime   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  headquarters Headquarters @relation(fields: [headquartersId], references: [id])
  patient      Patient?     @relation(fields: [patientId], references: [id])
  assignedTo   User?        @relation(fields: [assignedToId], references: [id])

  @@index([headquartersId, startTime, status])
}

// =======================
// 6. PERFORMANCE & ACADEMY ENGINE
// =======================

model PerformanceScore {
  id             String @id @default(uuid())
  headquartersId String // Tenant
  userId         String // Cuidador evaluado
  periodStart    DateTime
  periodEnd      DateTime
  
  systemScore    Float  // Base calculada eMAR/Cierres
  humanScore     Float? // Evaluación del supervisor (opcional)
  finalScore     Float

  systemFindings Json?  // Metadatos { missedPRN: 2 }

  createdAt      DateTime @default(now())
  
  headquarters   Headquarters @relation(fields: [headquartersId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([headquartersId, userId])
}

enum AcademyAssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model AcademyAssignment {
  id             String @id @default(uuid())
  headquartersId String 
  userId         String
  
  moduleCode     String // ID del curso formativo
  reason         String // Justificación del trigger
  status         AcademyAssignmentStatus @default(PENDING)
  
  assignedBySystem  Boolean @default(true) // Automático vs Manual
  assignedByUserId  String? // Si fue manual, el supervisor

  createdAt      DateTime @default(now())
  completedAt    DateTime?
  
  headquarters   Headquarters @relation(fields: [headquartersId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([headquartersId, userId, moduleCode])
}

// =======================
// CLEANING & SANITIZACIÓN
// =======================

model CleaningArea {
  id              String   @id @default(uuid())
  headquartersId  String
  name            String
  floor           String   // "FIRST_FLOOR" | "SECOND_FLOOR"
  category        String   // "BATHROOM" | "ROOM" | "COMMON" | "TRASH"
  roomNumber      String?
  requiresPhoto   Boolean  @default(false)
  isActive        Boolean  @default(true)
  order           Int      @default(0)

  headquarters    Headquarters @relation(fields: [headquartersId], references: [id])
  logs            CleaningLog[]
  requests        CleaningRequest[]
}

model CleaningLog {
  id              String   @id @default(uuid())
  areaId          String
  cleanedById     String
  headquartersId  String
  status          String   @default("COMPLETED") // COMPLETED | SKIPPED
  photoUrl        String?
  photoRequested  Boolean  @default(false)
  notes           String?
  cleanedAt       DateTime @default(now())

  area            CleaningArea   @relation(fields: [areaId], references: [id])
  cleanedBy       User           @relation(fields: [cleanedById], references: [id])
  headquarters    Headquarters   @relation(fields: [headquartersId], references: [id])
}

model CleaningRequest {
  id              String    @id @default(uuid())
  headquartersId  String
  requestedById   String
  areaId          String?
  areaName        String
  description     String
  photoUrl        String?
  status          String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | EXPIRED
  priority        String    @default("NORMAL")  // NORMAL | URGENT
  expiresAt       DateTime
  assignedToId    String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  headquarters    Headquarters   @relation(fields: [headquartersId], references: [id])
  requestedBy     User           @relation("CleaningRequestsCreated", fields: [requestedById], references: [id])
  assignedTo      User?          @relation("CleaningRequestsAssigned", fields: [assignedToId], references: [id])
  area            CleaningArea?  @relation(fields: [areaId], references: [id])
}

// =======================
// SOCIAL WORK MODULE
// =======================

model SocialWorkNote {
  id              String   @id @default(uuid())
  patientId       String
  headquartersId  String
  createdById     String
  content         String   @db.Text
  category        String   @default("GENERAL") // GENERAL | FAMILY | BENEFITS | LEGAL | INCIDENT
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient        @relation(fields: [patientId], references: [id])
  createdBy       User           @relation(fields: [createdById], references: [id])
  headquarters    Headquarters   @relation(fields: [headquartersId], references: [id])
}

model SocialWorkTask {
  id               String    @id @default(uuid())
  patientId        String
  headquartersId   String
  createdById      String
  assignedToId     String?
  title            String
  description      String?
  category         String    @default("FOLLOW_UP") // FOLLOW_UP | DOCUMENT | FAMILY | APPOINTMENT | BENEFIT
  status           String    @default("PENDING")   // PENDING | IN_PROGRESS | COMPLETED | CANCELLED
  priority         String    @default("NORMAL")    // LOW | NORMAL | HIGH | URGENT
  dueDate          DateTime?
  completedAt      DateTime?
  isZendiSuggested Boolean   @default(false)
  createdAt        DateTime  @default(now())

  patient          Patient        @relation(fields: [patientId], references: [id])
  createdBy        User           @relation(fields: [createdById], references: [id])
  assignedTo       User?          @relation("SocialWorkTasksAssigned", fields: [assignedToId], references: [id])
  headquarters     Headquarters   @relation(fields: [headquartersId], references: [id])
}

model SocialWorkBenefit {
  id              String    @id @default(uuid())
  patientId       String
  headquartersId  String
  type            String    // MEDICARE | MEDICAID | SNAP | PENSION | OTHER
  status          String    @default("ACTIVE") // ACTIVE | EXPIRED | PENDING | UNKNOWN
  details         String?
  expirationDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient         Patient        @relation(fields: [patientId], references: [id])
  headquarters    Headquarters   @relation(fields: [headquartersId], references: [id])
}

model SpecialistVisit {
  id              String   @id @default(uuid())
  patientId       String
  headquartersId  String
  specialistType  String   // DOCTOR | PODIATRIST | PSYCHOLOGIST | DENTIST | PSYCHIATRIST | OTHER
  specialistName  String?
  visitDate       DateTime
  nextVisitDate   DateTime?
  notes           String?
  createdById     String
  createdAt       DateTime @default(now())

  patient         Patient        @relation(fields: [patientId], references: [id])
  createdBy       User           @relation(fields: [createdById], references: [id])
  headquarters    Headquarters   @relation(fields: [headquartersId], references: [id])
}

// =======================
// ZONE INSPECTION ROUNDS (Supervisor)
// =======================

model ZoneInspection {
  id             String    @id @default(uuid())
  headquartersId String
  supervisorId   String
  roundType      String    // INICIO | MEDIO | CIERRE
  floor          Int       // 1 | 2
  zoneName       String
  checklistData  Json      // { limpieza: bool, seguridad: bool, residentes: bool, equipo: bool }
  observations   String?   @db.Text
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  headquarters Headquarters @relation(fields: [headquartersId], references: [id])
  supervisor   User         @relation(fields: [supervisorId], references: [id])
}

// =======================
// FASE 81: STAFF INTERNAL CHAT
// =======================
model StaffMessage {
  id             String   @id @default(uuid())
  headquartersId String
  senderId       String
  content        String   @db.Text
  type           String   @default("DIRECT") // DIRECT | BROADCAST
  recipientId    String? // null = broadcast a toda la sede
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  sender       User         @relation("SentStaffMessages", fields: [senderId], references: [id])
  recipient    User?        @relation("ReceivedStaffMessages", fields: [recipientId], references: [id])
  headquarters Headquarters @relation(fields: [headquartersId], references: [id])

  @@index([headquartersId, type, createdAt])
  @@index([recipientId, isRead])
}

// =======================
// Sprint G — Zendi Director Briefing (GPT-4o)
// Cacheado por día clínico; scope = hqId o 'ALL'.
// =======================
model DirectorBriefing {
    id             String   @id @default(uuid())
    scope          String   // 'ALL' para consolidado, o un headquartersId
    generatedAt    DateTime @default(now())
    clinicalDay    DateTime // Inicio del día clínico (6 AM AST) al que corresponde el briefing
    summary        String   @db.Text // Texto plano breve (fallback / encabezado)
    bullets        Json     // [{ priority: 'CRITICAL'|'HIGH'|'MEDIUM'|'LOW', title, description, action }]
    generatedById  String?
    model          String   @default("gpt-4o")

    generatedBy User? @relation(fields: [generatedById], references: [id])

    @@unique([scope, clinicalDay])
    @@index([scope, generatedAt])
}
